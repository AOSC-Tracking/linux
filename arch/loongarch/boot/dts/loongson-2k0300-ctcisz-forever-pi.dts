/dts-v1/;

#include "loongson-2k0300.dtsi"

/ {
	compatible = "ctcisz,forever-pi", "loongson,ls2k0300";
	model = "CTCISZ Forever Pi";
	product = "LS2K0300-99PI-WIFI";

	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		led1 {
			label = "led1";
			gpios = <&gpio 83 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "heartbeat";
			default-state = "on";
		};
	};

	memory@200000 {
		device_type = "memory";
		reg = <0 0x00200000 0 0x0ee00000>,
		      <0 0x90000000 0 0x10000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		linux,cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0 0x02000000>;
			linux,cma-default;
		};
	};

	sdio_pwrseq: sdio-pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <&sdio0en>;
		reset-gpios = <&gpio 81 GPIO_ACTIVE_HIGH>;
	};
};

&pinctrl {
	func-gpio {
		sdio0en: pinmux_G81_as_sdio0en {
			pinmux = <PINMUX(81, 0x0)>;
		};
	};
};

&uart0 {
	status = "okay";
};

&gmac0 {
	status = "okay";
	phy-handle = <&yt8531h0>;
	mdio {
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "snps,dwmac-mdio";

		yt8531h0: ethernet-phy@0 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <0>;
			motorcomm,led0_cfg = <0x40>; //千兆常亮
			motorcomm,led1_cfg = <0x30>; //百兆 十兆常亮
			motorcomm,led2_cfg = <0x2600>; //有数据时闪烁
		};
	};
};

&can2 {
	status = "okay";
};

&can3 {
	status = "okay";
};

&sdio1 {
	status = "okay";
};
